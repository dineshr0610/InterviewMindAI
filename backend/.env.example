# InterviewMind AI Backend Environment Variables Template

# === Database Connections (Supabase PostgreSQL) ===
# Connection string with percent-encoded special characters (%40 for @)
DATABASE_URL=postgresql://postgres.your_project_ref:your_password@aws-1-ap-south-1.pooler.supabase.com:5432/postgres
DIRECT_URL=postgresql://postgres.your_project_ref:your_password@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# === Supabase Configuration ===
SUPABASE_URL=https://your_project_ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
SUPABASE_SECRET_KEY=sb_secret_your_key_here

# === AI Engine Configuration ===
GEMINI_API_KEY=your_gemini_api_key_here

# === Server Configuration ===
HOST=0.0.0.0
PORT=8000
DEBUG=false
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","https://your-frontend.vercel.app"]
